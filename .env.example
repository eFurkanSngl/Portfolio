# Frontend. GitHub Pages kullanacaksan Vercel/Railway backend URL'ini tam yaz.
# Alternatif: public/stats-config.js icindeki window.PORTFOLIO_STATS_ENDPOINT de kullanilabilir.
# Ornek: VITE_STATS_ENDPOINT=https://portfolio-stats.vercel.app/api/stats
VITE_STATS_ENDPOINT=

# Backend. Bunlar Vercel/Railway environment variables tarafinda durmali.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVENTS_TABLE=portfolio_visitor_events
ADMIN_PASSWORD=
ALLOWED_ORIGIN=https://efurkansngl.github.io
